# ── Serveur ────────────────────────────────────────────────
PORT=3000
BASE_URL=https://xxxx.ngrok-free.app  # remplacer par ton URL ngrok

# ── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Ollama NLU ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120000

# ── Auto-répondeur SMS ──────────────────────────────────────
# Tons : pro | sec | friendly | sarcastique | wolf-inc
SMS_TONE=friendly

# ── TERMINATOR v7 (DSP audio) ──────────────────────────────
# Chemin vers audioProcessor.js de votre build TERMINATOR v7
# Laissez vide si vous mettez les fichiers dans src/terminator/
TERMINATOR_PATH=./src/terminator/audioProcessor.js

# ── Whisper STT ────────────────────────────────────────────
# Options : 'mock' | 'local-server' | 'openai'
WHISPER_BACKEND=mock

# Si WHISPER_BACKEND=local-server :
WHISPER_SERVER_URL=http://localhost:9000/transcribe

# Si WHISPER_BACKEND=openai :
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── TTS ────────────────────────────────────────────────────
# Options : 'mock' | 'piper' | 'elevenlabs' | 'azure'
TTS_PROVIDER=mock

# Si TTS_PROVIDER=piper (gratuit, local) :
PIPER_BINARY=piper
PIPER_MODEL_PATH=./models/fr_FR-upmc-medium.onnx

# Si TTS_PROVIDER=elevenlabs :
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Si TTS_PROVIDER=azure (5h/mois gratuit) :
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=fr-FR-DeniseNeural

# ── Agent ──────────────────────────────────────────────────
EVENTS_FILE=./data/events.json
MAX_EVENTS=500
