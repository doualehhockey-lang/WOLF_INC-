# ── Serveur ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
BASE_URL=https://xxxx.ngrok-free.app
AUDIO_DIR=./public/audio

# ── Sécurité — OBLIGATOIRES en production ────────────────────────────────────
# Générer avec : openssl rand -hex 32
PHONE_SALT=change-me-at-least-16-chars-long
JWT_SECRET=change-me-minimum-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-different-32-chars-refresh-secret
# Clés API machine-to-machine (séparées par des virgules)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=test-key

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules). '*' interdit en production.
CORS_ORIGINS=http://localhost:3000,https://your-frontend.com

# ── Twilio ───────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1XXXXXXXXXX

# ── PostgreSQL (optionnel — JSON file store si absent) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=wolf
DB_PASSWORD=
DB_NAME=wolf_engine
# DB_SSL=true   # décommenter en production

# ── Redis (optionnel — in-memory fallback si absent) ─────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama / NLU local ────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120000

# ── Claude (NLU cloud — prioritaire sur Ollama si configuré) ─────────────────
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── TTS ──────────────────────────────────────────────────────────────────────
# Options : mock | piper | elevenlabs | azure
TTS_PROVIDER=mock

# Si TTS_PROVIDER=piper (gratuit, local) :
PIPER_BINARY=piper
PIPER_MODEL_PATH=./models/fr_FR-upmc-medium.onnx

# Si TTS_PROVIDER=elevenlabs :
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Si TTS_PROVIDER=azure (5h/mois gratuit) :
AZURE_TTS_KEY=
AZURE_TTS_REGION=eastus
AZURE_TTS_VOICE=fr-FR-DeniseNeural

# ── STT / Whisper ─────────────────────────────────────────────────────────────
# Options : mock | local-server | openai
WHISPER_BACKEND=mock
WHISPER_SERVER_URL=http://localhost:9000/transcribe
WHISPER_TIMEOUT=15000
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Agent ─────────────────────────────────────────────────────────────────────
EVENTS_FILE=./data/events.json
MAX_EVENTS=500
# Ton SMS : pro | sec | friendly | sarcastique | wolf-inc
SMS_TONE=friendly

# ── OpenTelemetry (Jaeger / Grafana Tempo) ────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4318

# ── Feature flags ─────────────────────────────────────────────────────────────
# In-process cache TTL for Redis-backed feature flags (milliseconds).
# Default: 30000 (30s). Lower in staging to propagate changes faster.
FEATURE_FLAGS_CACHE_TTL_MS=30000

# ── Observability / metrics ────────────────────────────────────────────────────
# Bearer token protecting the /metrics endpoint (Prometheus scrape).
# Générer avec : openssl rand -hex 32
METRICS_TOKEN=change-me-at-least-32-characters-long

# ── Soak / staging ────────────────────────────────────────────────────────────
# Used by scripts/staging-soak.sh to identify the Prometheus job name.
# Change to match your Prometheus scrape job for the staging environment.
PROMETHEUS_JOB=wolf-engine-staging
# Prometheus URL for soak monitoring script (local port-forward or in-cluster).
PROMETHEUS_URL=http://localhost:9090
